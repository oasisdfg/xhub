<Window x:Class="xhub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:xhub.Views"
        xmlns:vm="clr-namespace:xhub.ViewModels"
        Title="xhub"
        Width="780" Height="620"
        MinWidth="560" MinHeight="400"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Style="{StaticResource DarkWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                Padding="28,20,28,18"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="xhub"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBlock Text="Your software, one place."
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Program list ────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,20,22,8">
            <ItemsControl ItemsSource="{Binding Programs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ProgramCard/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Status bar ──────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource StatusBarBrush}"
                Padding="28,8"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </Border>
    </Grid>

</Window>
