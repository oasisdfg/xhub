<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Colours ===== -->
    <Color x:Key="BackgroundColor">#FF1A1A1A</Color>
    <Color x:Key="SurfaceColor">#FF242424</Color>
    <Color x:Key="CardColor">#FF2A2A2A</Color>
    <Color x:Key="CardBorderColor">#FF383838</Color>
    <Color x:Key="HeaderColor">#FF1E1E1E</Color>
    <Color x:Key="StatusBarColor">#FF161616</Color>

    <Color x:Key="PrimaryTextColor">#FFF0F0F0</Color>
    <Color x:Key="SecondaryTextColor">#FF9A9A9A</Color>
    <Color x:Key="MutedTextColor">#FF666666</Color>

    <Color x:Key="AccentColor">#FF4A9EFF</Color>
    <Color x:Key="AccentHoverColor">#FF6AB4FF</Color>
    <Color x:Key="AccentPressedColor">#FF2A7EDF</Color>

    <Color x:Key="UpdateAccentColor">#FF40C080</Color>
    <Color x:Key="UpdateAccentHoverColor">#FF60D090</Color>

    <Color x:Key="DisabledButtonColor">#FF3A3A3A</Color>
    <Color x:Key="DisabledTextColor">#FF585858</Color>

    <Color x:Key="StatusReadyColor">#FF9A9A9A</Color>
    <Color x:Key="StatusInstalledColor">#FF40C080</Color>
    <Color x:Key="StatusUpdateColor">#FFFFA040</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush"           Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="HeaderBrush"         Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="StatusBarBrush"      Color="{StaticResource StatusBarColor}"/>

    <SolidColorBrush x:Key="PrimaryTextBrush"    Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"  Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush"      Color="{StaticResource MutedTextColor}"/>

    <SolidColorBrush x:Key="AccentBrush"         Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"  Color="{StaticResource AccentPressedColor}"/>

    <SolidColorBrush x:Key="UpdateAccentBrush"   Color="{StaticResource UpdateAccentColor}"/>

    <SolidColorBrush x:Key="DisabledButtonBrush" Color="{StaticResource DisabledButtonColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush"   Color="{StaticResource DisabledTextColor}"/>

    <SolidColorBrush x:Key="StatusReadyBrush"    Color="{StaticResource StatusReadyColor}"/>
    <SolidColorBrush x:Key="StatusInstalledBrush" Color="{StaticResource StatusInstalledColor}"/>
    <SolidColorBrush x:Key="StatusUpdateBrush"   Color="{StaticResource StatusUpdateColor}"/>

    <!-- ===== Converters ===== -->
    <!-- No converters needed; status brushes are resolved in ProgramCard via DataTriggers -->

    <!-- ===== Window Style ===== -->
    <Style x:Key="DarkWindowStyle" TargetType="Window">
        <Setter Property="Background"   Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground"   Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="13"/>
    </Style>

    <!-- ===== ScrollBar Style ===== -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#FF404040"
                                                    CornerRadius="3"
                                                    Margin="1,2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ===== Button Base Style ===== -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="FontSize"            Value="12"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="Foreground"          Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Background"          Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="18,7"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="MinWidth"            Value="90"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource AccentPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource DisabledButtonBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource DisabledTextBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Update variant (green accent) -->
    <Style x:Key="UpdateButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource UpdateAccentBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource UpdateAccentHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ProgressBar Style ===== -->
    <Style x:Key="DarkProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height"           Value="4"/>
        <Setter Property="Background"       Value="#FF3A3A3A"/>
        <Setter Property="Foreground"       Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"/>
                        <Border x:Name="PART_Indicator"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
